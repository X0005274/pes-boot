# 기본: 텍스트 자동 감지 + 저장소/체크아웃 모두 LF 고정
* text=auto eol=lf

# 명시적 텍스트 파일 (LF)
*.java   text eol=lf
*.xml    text eol=lf
*.yml    text eol=lf
*.yaml   text eol=lf
*.sql    text eol=lf
*.md     text eol=lf
*.properties text eol=lf
*.gitignore  text eol=lf
*.gitattributes text eol=lf

# 바이너리 (정규화 금지)
*.jar    binary
*.class  binary
*.png    binary
*.jpg    binary
*.gif    binary
*.ico    binary
