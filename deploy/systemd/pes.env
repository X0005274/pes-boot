# /opt/pes/bin/pes.env  (systemd EnvironmentFile)
SPRING_PROFILES_ACTIVE=prod
PES_HOME=/opt/pes
PES_DB_URL=jdbc:oracle:thin:@//db-host:1521/PESPDB
PES_DB_USER=pes
PES_DB_PASSWORD=changeme
PES_FLYWAY_ENABLED=true
PES_JPA_DDL_AUTO=validate
PES_ACTUATOR_ENDPOINTS=health,info,metrics
# HubDB (optional)
PES_HUB_ENABLED=false
PES_HUB_DB_URL=jdbc:oracle:thin:@//hub-host:1521/HUBPDB
PES_HUB_DB_USER=hub
PES_HUB_DB_PASSWORD=changeme
PES_HUB_SCHED_ENABLED=false
